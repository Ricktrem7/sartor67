<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>SARTOR 67</title>
<link rel="icon" type="image/svg+xml" href="~/images/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400&family=Montserrat:wght@300;400;500&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

    <!-- NAVBAR -->
    <header class="navbar" id="navbar">
        <div class="navbar__left">
            <nav class="navbar__menu">
                <a href="#">COLLECTIONS</a>
                <a href="#">UNIVERSE</a>
                <a href="#">MADE TO MEASURE</a>
            </nav>
        </div>

        <div class="navbar__center">
            <a href="/" class="navbar__logo">SARTOR 67</a>
        </div>

        <div class="navbar__right">
            <a href="#" class="navbar__icon" aria-label="Search">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
                </svg>
            </a>
            <a href="#" class="navbar__icon" aria-label="Account">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>
                </svg>
            </a>
            <a href="#" class="navbar__icon" aria-label="Bag">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/>
                </svg>
            </a>
        </div>
    </header>

    <!-- CONTEÚDO DA PÁGINA -->
    <main>
        @RenderBody()
    </main>

    <!-- FOOTER -->
    <footer class="footer">
        <div class="footer__top">
            <div class="footer__col">
                <h4>COLLECTIONS</h4>
                <a href="#">Men's Ready to Wear</a>
                <a href="#">Made to Measure</a>
                <a href="#">Accessories</a>
                <a href="#">Gifts</a>
            </div>
            <div class="footer__col">
                <h4>UNIVERSE</h4>
                <a href="#">About Sartor 67</a>
                <a href="#">Craftsmanship</a>
                <a href="#">Sustainability</a>
                <a href="#">Careers</a>
            </div>
            <div class="footer__col">
                <h4>CLIENT SERVICES</h4>
                <a href="#">Contact Us</a>
                <a href="#">Store Locator</a>
                <a href="#">Shipping & Returns</a>
                <a href="#">FAQ</a>
            </div>
            <div class="footer__col">
                <h4>FOLLOW US</h4>
                <a href="#">Instagram</a>
                <a href="#">Facebook</a>
                <a href="#">YouTube</a>
                <a href="#">WhatsApp</a>
            </div>
        </div>
        <div class="footer__bottom">
            <span>© 2025 SARTOR 67. ALL RIGHTS RESERVED.</span>
            <div class="footer__legal">
                <a href="#">Privacy Policy</a>
                <a href="#">Cookie Policy</a>
                <a href="#">Terms & Conditions</a>
            </div>
        </div>
    </footer>

    <script src="~/js/site.js" asp-append-version="true"></script>
</body>
</html>